NODE_ENV=development
PORT=4000
APP_NAME=Sidago CRM Backend
APP_VERSION=1.0.0
API_PREFIX=api
GLOBAL_PREFIX=api
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
COOKIE_DOMAIN=localhost

DATABASE_URL=postgres://root:secure_password@localhost:5432/global_app_db
DATABASE_ADMIN_URL=
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

REDIS_URL=redis://:redis_secure_password@localhost:6379
REDIS_KEY_PREFIX=sidago:

JWT_ACCESS_SECRET=replace-with-long-access-secret
JWT_REFRESH_SECRET=replace-with-long-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Sidago CRM <noreply@sidago.local>

THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10

QUEUE_PREFIX=sidago
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF=5000
QUEUE_CONCURRENCY=5

LOG_FILE_MODE=single
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

FRONTEND_URL=http://localhost:3000
WS_CORS_ORIGIN=http://localhost:3000
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=storage/local
STORAGE_LOCAL_BASE_URL=/storage/local
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=false
STORAGE_S3_PREFIX=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
